#!/usr/bin/env bash
# lucy-build-context: Build relationship/email-derived context for a group
# Scans Gmail via google-workspace MCP for relevant conversations and synthesizes
# them into context files the orchestrator can use.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../config.sh"

CONTEXT_DIR="$LUCY_DIR/context"

usage() {
  cat <<'USAGE'
Usage: lucy-build-context --group <name>

Scans Gmail for conversations relevant to the specified group and synthesizes
them into a context/{group}-relationships.md file that the orchestrator uses
to give agents people/relationship context.

Options:
  --group <name>   Group to build context for (required)
  --force          Rebuild even if the context file is less than 24h old

Configuration:
  Each group needs a context/{group}-sources.json file specifying:
  - gmail_accounts: which Gmail accounts to search
  - search_queries: Gmail search queries to run
  - contacts: key contacts to track
  - refresh_interval_hours: how often to rebuild (default: 24)

Example:
  lucy-build-context --group myproject
USAGE
  exit 1
}

GROUP=""
FORCE=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --group) GROUP="$2"; shift 2 ;;
    --force) FORCE=true; shift ;;
    -h|--help) usage ;;
    *) echo "Unknown option: $1"; usage ;;
  esac
done

[[ -z "$GROUP" ]] && echo "Error: --group is required" && usage

# Check for sources config
SOURCES_FILE="$CONTEXT_DIR/${GROUP}-sources.json"
if [ ! -f "$SOURCES_FILE" ]; then
  echo "Error: No sources config at $SOURCES_FILE"
  echo "Create one with gmail_accounts, search_queries, and contacts fields."
  exit 1
fi

# Check if rebuild is needed
OUTPUT_FILE="$CONTEXT_DIR/${GROUP}-relationships.md"
if ! $FORCE && [ -f "$OUTPUT_FILE" ]; then
  REFRESH_HOURS=$(jq -r '.refresh_interval_hours // 24' "$SOURCES_FILE")
  FILE_AGE_HOURS=$(( ($(date +%s) - $(stat -c %Y "$OUTPUT_FILE")) / 3600 ))
  if [ "$FILE_AGE_HOURS" -lt "$REFRESH_HOURS" ]; then
    echo "Context file is ${FILE_AGE_HOURS}h old (refresh every ${REFRESH_HOURS}h). Use --force to rebuild."
    exit 0
  fi
fi

echo "Building context for group '$GROUP'..."
echo "  Sources: $SOURCES_FILE"
echo "  Output:  $OUTPUT_FILE"

# Read sources config
ACCOUNTS=$(jq -r '.gmail_accounts[]' "$SOURCES_FILE" 2>/dev/null)
QUERIES=$(jq -r '.search_queries[]' "$SOURCES_FILE" 2>/dev/null)
CONTACTS=$(jq -r '.contacts[]' "$SOURCES_FILE" 2>/dev/null)

# Launch Claude to do the synthesis (it has access to google-workspace MCP)
PROMPT_TMP=$(mktemp)
cat > "$PROMPT_TMP" << PROMPT_EOF
You are building a relationship context file for the '$GROUP' group.

Search Gmail for recent conversations and synthesize them into a context file.

## Gmail accounts to search
$(echo "$ACCOUNTS" | sed 's/^/- /')

## Search queries to run
$(echo "$QUERIES" | sed 's/^/- /')

## Key contacts to track
$(echo "$CONTACTS" | sed 's/^/- /')

## Instructions
1. Use the google-workspace MCP tool search_gmail_messages to search each query
2. For each relevant thread, extract: who, what was discussed, decisions made, action items
3. Synthesize into sections per contact with:
   - Last contact date
   - Recent topics
   - Key decisions
   - Open items

4. Write the result to: $OUTPUT_FILE

Format as markdown with ## headers per contact.
Keep it concise: 1-3 bullet points per section, focus on actionable info.
Only include the last 30 days of activity.

Start searching now.
PROMPT_EOF

echo "Launching Claude to synthesize email context..."

# Run in a tmux session so it doesn't block
TMUX_SESSION="lucy-build-ctx-${GROUP}"
if tmux has-session -t "$TMUX_SESSION" 2>/dev/null; then
  echo "Context build already running for '$GROUP'."
  exit 0
fi

AGENT_LOG="$LUCY_DIR/logs/build-context-${GROUP}.log"
tmux new-session -d -s "$TMUX_SESSION" -c "$CONTEXT_DIR"
tmux send-keys -t "$TMUX_SESSION" "claude --model claude-haiku-4-5 --dangerously-skip-permissions -p \"\$(cat $PROMPT_TMP)\" > $AGENT_LOG 2>&1; rm -f $PROMPT_TMP; exit" Enter

log "BUILD-CONTEXT started group=$GROUP"
echo "Context build started in background."
echo "  Attach: tmux attach -t $TMUX_SESSION"
echo "  Log:    tail -f $AGENT_LOG"
