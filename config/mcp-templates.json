{
  "_comment": "MCP server templates. Fill in your credentials before use.",
  "google-workspace": {
    "command": "uvx",
    "args": [
      "workspace-mcp",
      "--tool-tier",
      "complete"
    ],
    "env": {
      "GOOGLE_OAUTH_CLIENT_ID": "YOUR_OAUTH_CLIENT_ID",
      "GOOGLE_OAUTH_CLIENT_SECRET": "YOUR_OAUTH_CLIENT_SECRET",
      "WORKSPACE_MCP_PORT": "0"
    }
  },
  "google-sheets-deep": {
    "command": "uvx",
    "args": [
      "mcp-google-sheets@latest",
      "--include-tools",
      "get_sheet_data,update_cells,list_spreadsheets,list_sheets,batch_update_cells,get_sheet_formulas,get_multiple_sheet_data,get_multiple_spreadsheet_summary,find_in_spreadsheet,add_rows,add_columns,batch_update"
    ],
    "env": {
      "CREDENTIALS_PATH": "$HOME/.google_workspace_mcp/credentials.json",
      "TOKEN_PATH": "$HOME/.google_workspace_mcp/sheets_token.json"
    }
  },
  "bigquery": {
    "command": "uvx",
    "args": [
      "mcp-server-bigquery",
      "--project",
      "YOUR_GCP_PROJECT",
      "--location",
      "US"
    ]
  },
  "github": {
    "command": "bash",
    "args": [
      "-c",
      "GITHUB_PERSONAL_ACCESS_TOKEN=$(gh auth token 2>/dev/null) exec github-mcp-server stdio"
    ]
  },
  "google-ads": {
    "command": "google-ads-mcp",
    "env": {
      "GOOGLE_ADS_DEVELOPER_TOKEN": "YOUR_DEVELOPER_TOKEN",
      "GOOGLE_ADS_LOGIN_CUSTOMER_ID": "YOUR_MCC_ID",
      "GOOGLE_APPLICATION_CREDENTIALS": "$HOME/.google_workspace_mcp/serviceaccount.json",
      "GOOGLE_PROJECT_ID": "YOUR_GCP_PROJECT"
    }
  },
  "google-analytics": {
    "command": "analytics-mcp",
    "env": {
      "GOOGLE_APPLICATION_CREDENTIALS": "$HOME/.google_workspace_mcp/serviceaccount.json",
      "GOOGLE_PROJECT_ID": "YOUR_GCP_PROJECT"
    }
  },
  "chrome-devtools": {
    "command": "cmd.exe",
    "args": [
      "/c",
      "npx",
      "-y",
      "@anthropic-ai/chrome-devtools-mcp@latest"
    ],
    "env": {
      "CHROME_DEBUG_PORT": "9222",
      "NODE_OPTIONS": "--max-old-space-size=2048"
    }
  },
  "gtm": {
    "command": "gtm-mcp",
    "env": {
      "GTM_CREDENTIALS_FILE": "$HOME/.config/gtm-mcp/credentials.json",
      "GTM_TOKEN_FILE": "$HOME/.config/gtm-mcp/token.json"
    }
  }
}
