{
  "permissions": {
    "allow": [
      "Bash(code:*)",
      "Bash(powershell -Command:*)",
      "Bash(/home/user/.local/bin/uvx --from workspace-mcp workspace-mcp --help)",
      "Bash(python3 -c \"import sys,json; d=json.load\\(sys.stdin\\); [print\\(k\\) for k in d.get\\(''''mcpServers'''',{}\\)]\")",
      "Bash(~/.claude/skills/gstack/browse/dist/browse navigate:*)",
      "Bash(gh repo:*)",
      "WebSearch",
      "mcp__github__search_repositories",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.browser-use.com)",
      "WebFetch(domain:docs.browserbase.com)",
      "WebFetch(domain:docs.stagehand.dev)",
      "Bash(gh api:*)",
      "Bash(gh issue:*)",
      "mcp__github__get_file_contents"
    ],
    "defaultMode": "dontAsk"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/name-session.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/compact-suggest.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/Claude/claude-code-toolkit/hooks/bash-injection-guard.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/zapier-title-check.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/no-gstack-login.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/trivial-pr-guard.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/disk-check.sh\"",
            "timeout": 5,
            "statusMessage": "Checking disk space..."
          }
        ]
      },
      {
        "matcher": "mcp__chrome-devtools__evaluate_script",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/zapier-title-check.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__google-workspace__",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/workspace-token-gate.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__google-sheets-deep__",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/workspace-token-gate.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ToolSearch",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/mcp-tool-not-found.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__chrome.devtools__",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/chrome-tab-track.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/headless-blocked-hint.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/verification-code-hint.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/notify-idle.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/enforce-memory-promises.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/fix-last-prompt.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/session-save.sh\"",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/chrome-tab-cleanup.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/chrome-mcp-cleanup.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/agent-browser-cleanup.sh\"",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/cleanup-owner.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "enabledPlugins": {},
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "autoUpdatesChannel": "stable"
}
